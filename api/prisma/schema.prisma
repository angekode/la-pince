// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Fichier principal de configuration Prisma.
// Il définit :
// - le générateur du client
// - la connexion à la base
// - les modèles (tables) et leurs relations

generator client {
  provider = "prisma-client-js"                 // Génère le client Prisma en JavaScript
}

datasource db {
  provider = "postgresql"                       // Type de base de données
  url      = env("DATABASE_URL")                // URL de connexion
}

//
// ─────────────────────────────────────────────
//   MODEL : USER
// ─────────────────────────────────────────────
//

model User {
  id        Int       @id @default(autoincrement())       // Clé primaire auto-incrémentée

  firstname  String
  lastname String
  email     String    @unique                             // Email unique
  password  String

  // Relations
  expenses  Expense[]                                     // Un utilisateur a plusieurs dépenses
  budgets Budget[]                                        // Un utilisateur a plusieurs budgets

  createdAt DateTime  @default(now()) @map("created_at")  // Nom de colonne personnalisé  
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("user")                                           // Nom réel de la table en DB
}

//
// ─────────────────────────────────────────────
//   MODEL : CATEGORY
// ─────────────────────────────────────────────
//

model Category {
  id        Int       @id @default(autoincrement())
  name      String

  // Relations
  expenses  Expense[]                                       // Une catégorie contient plusieurs dépenses
  budgets Budget[]                                          // Une catégorie contient plusieurs budgets

  @@map("category")
}

//
// ─────────────────────────────────────────────
//   MODEL : EXPENSE (transactions)
// ─────────────────────────────────────────────
//

model Expense {
  id          Int       @id @default(autoincrement())
  label       String
  amount      Float
  date        DateTime  @default(now())
  description String?

  // Foreign keys
  userId      Int
  categoryId  Int

  // Relations
  user        User      @relation(fields: [userId], references: [id])
  category    Category  @relation(fields: [categoryId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("expense")
}

//
// ─────────────────────────────────────────────
//   MODEL : BUDGET
// ─────────────────────────────────────────────
//

model Budget {
  id          Int       @id @default(autoincrement())
  limit       Int

  // Foreign keys
  userId      Int
  categoryId  Int

  // Relations
  user        User      @relation(fields: [userId], references: [id])
  category    Category  @relation(fields: [categoryId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("budget")
}